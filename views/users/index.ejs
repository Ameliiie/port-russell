<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Utilisateurs</title>
</head>

<body>

    <h1>Liste des Utilisateurs</h1>

    <a href="/dashboard">Retour Dashboard</a>

    <hr>

    <ul>

        <% users.forEach(user => { %>

            <li>
                <%= user.username %> - <%= user.email %>
            </li>

        <% }) %>

    </ul>

</body>

</html>