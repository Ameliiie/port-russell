<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Détail Réservation</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <h1>Détail Réservation</h1>

    <a href="/reservations/view/list">
        Retour à la liste
    </a>

    <hr>

    <p>
        <strong>Client :</strong>
        <%= reservation.clientName %>
    </p>

    <p>
        <strong>Bateau :</strong>
        <%= reservation.boatName %>
    </p>

    <p>
        <strong>Catway :</strong>
        <%= reservation.catwayNumber %>
    </p>

    <p>
        <strong>Début :</strong>
        <%= reservation.startDate.toLocaleDateString("fr-FR") %>
    </p>

    <p>
        <strong>Fin :</strong>
        <%= reservation.endDate.toLocaleDateString("fr-FR") %>
    </p>
    <hr>

    <a href="/reservations/view/edit/<%= reservation._id %>"> Modifier</a>
    <br><br>

    <form action="/reservations/view/delete/<%= reservation._id %>" method="POST">

        <button type="submit"> Supprimer</button>

    </form>
</body>

</html>